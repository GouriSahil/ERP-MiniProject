# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/erp-miniproject

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
